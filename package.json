{
  "name": "bizpilothub",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "npm run dev --workspace @bizpilothub/web",
    "dev:api": "npm run dev --workspace @bizpilothub/api",
    "build": "turbo run build",
    "build:web": "npm run build --workspace @bizpilothub/web",
    "build:api": "npm run build --workspace @bizpilothub/api",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
