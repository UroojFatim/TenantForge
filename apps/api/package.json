{
  "name": "@bizpilothub/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --platform node --dts --clean --out-dir dist",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@bizpilothub/types": "0.1.0",
    "@bizpilothub/utils": "0.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@bizpilothub/eslint-config": "0.1.0",
    "@bizpilothub/tsconfig": "0.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "eslint": "^10.3.0",
    "tsx": "^4.20.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}